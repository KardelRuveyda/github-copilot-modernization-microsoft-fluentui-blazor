@using Microsoft.FluentUI.AspNetCore.Components

<FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12" Style="padding:10px 14px;">
    <FluentIcon Value="@Icon" Color="Color.Custom" CustomColor="@CustomColor" />
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
        <span style="font-size:13px;">@Title</span>
        <small style="color:var(--neutral-foreground-hint); font-size:12px;">@Subtitle</small>
    </FluentStack>
</FluentStack>

@code {
    [Parameter, EditorRequired] public Icon Icon { get; set; } = default!;
    [Parameter] public string CustomColor { get; set; } = "#0078d4";
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Subtitle { get; set; }
}
