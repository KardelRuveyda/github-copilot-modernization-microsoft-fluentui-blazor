@page "/reports"
@inject AuthState Auth
@inject LocalizationService L
@inject IHttpClientFactory HttpFactory
@inject ExcelExportService Excel
@inject IToastService Toast
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>@L.T("rep.title") - FluentUI Demo</PageTitle>

<AuthGuard />

<div class="az-page-header">
    <h1 class="az-page-title">
        <span class="az-page-title-icon"><FluentIcon Value="@(new Icons.Filled.Size20.DataBarVertical())" Color="Color.Fill" /></span>
        @L.T("rep.title")
    </h1>
    <p class="az-page-subtitle">@L.T("rep.subtitle")</p>

    <FluentToolbar Style="margin-top:8px; background:transparent; padding:0;">
        <FluentButton Appearance="Appearance.Stealth"
                      IconStart="@(new Icons.Regular.Size16.ArrowClockwise())"
                      OnClick="ReloadAsync">@L.T("common.refresh")</FluentButton>
        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Icons.Regular.Size16.ArrowDownload())"
                      OnClick="ExportAsync">@L.T("common.export")</FluentButton>
        <FluentButton Appearance="Appearance.Stealth"
                      IconStart="@(new Icons.Regular.Size16.Print())"
                      OnClick="@(() => Print())">Print</FluentButton>
    </FluentToolbar>
</div>

@if (_loading)
{
    <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding:60px;">
        <FluentProgressRing />
    </FluentStack>
}
else
{
    <div class="az-grid-4" style="margin-bottom:16px;">
        <FluentCard>
            <FluentStack VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
                <div class="az-kpi-icon" style="background:#0078d4;"><FluentIcon Value="@(new Icons.Filled.Size24.Money())" Color="Color.Fill" /></div>
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                    <div class="az-kpi-value">@_total.ToString("N0") ₺</div>
                    <div class="az-kpi-label">@L.T("rep.totalAmount")</div>
                    <div class="az-kpi-delta up">▲ +18% YoY</div>
                </FluentStack>
            </FluentStack>
        </FluentCard>

        <FluentCard>
            <FluentStack VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
                <div class="az-kpi-icon" style="background:#107c10;"><FluentIcon Value="@(new Icons.Filled.Size24.ArrowTrending())" Color="Color.Fill" /></div>
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                    <div class="az-kpi-value">@_avg.ToString("N0") ₺</div>
                    <div class="az-kpi-label">@L.T("rep.avgAmount")</div>
                    <div class="az-kpi-delta up">▲ +6%</div>
                </FluentStack>
            </FluentStack>
        </FluentCard>

        <FluentCard>
            <FluentStack VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
                <div class="az-kpi-icon" style="background:#f7630c;"><FluentIcon Value="@(new Icons.Filled.Size24.BuildingFactory())" Color="Color.Fill" /></div>
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                    <div class="az-kpi-value" style="font-size:18px;">@_topDept</div>
                    <div class="az-kpi-label">@L.T("rep.topDept")</div>
                    <div class="az-kpi-delta">@_topDeptAmount.ToString("N0") ₺</div>
                </FluentStack>
            </FluentStack>
        </FluentCard>

        <FluentCard>
            <FluentStack VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
                <div class="az-kpi-icon" style="background:#5c2d91;"><FluentIcon Value="@(new Icons.Filled.Size24.CheckmarkCircle())" Color="Color.Fill" /></div>
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                    <div class="az-kpi-value">@_approvalRate.ToString("N0")%</div>
                    <div class="az-kpi-label">@L.T("rep.approvalRate")</div>
                    <FluentProgress Value="@((int)_approvalRate)" Width="120px" />
                </FluentStack>
            </FluentStack>
        </FluentCard>
    </div>

    <div class="az-grid-2">
        <FluentCard>
            <h3 class="az-tile-title" style="margin:0 0 12px;">@L.T("rep.byDeptTitle")</h3>
            <div class="bar-chart">
                @foreach (var d in _byDept)
                {
                    var pct = _byDeptMax == 0 ? 0 : (int)(d.Total * 100 / _byDeptMax);
                    <div class="bar-row">
                        <div class="bar-label">@d.Department</div>
                        <div class="bar-track">
                            <div class="bar-fill" style="width:@(pct)%"></div>
                        </div>
                        <div class="bar-value">@d.Total.ToString("N0") ₺</div>
                    </div>
                }
            </div>
        </FluentCard>

        <FluentCard>
            <h3 class="az-tile-title" style="margin:0 0 12px;">@L.T("rep.byTypeTitle")</h3>
            <div class="donut-list">
                @foreach (var (t, i) in _byType.Select((x, i) => (x, i)))
                {
                    var pct = _total == 0 ? 0 : (decimal)t.Total * 100m / _total;
                    <div class="donut-row">
                        <span class="donut-dot" style="background:@DotColor(i);"></span>
                        <span class="donut-label">@t.Type</span>
                        <span class="donut-bar"><span style="width:@(pct.ToString("N0"))%; background:@DotColor(i);"></span></span>
                        <span class="donut-pct">@pct.ToString("N0")%</span>
                    </div>
                }
            </div>
        </FluentCard>
    </div>

    <FluentCard Style="margin-top:16px;">
        <h3 class="az-tile-title" style="margin:0 0 12px;">@L.T("rep.byDateTitle")</h3>
        <svg viewBox="0 0 800 260" preserveAspectRatio="none" style="width:100%; height:260px; display:block;">
            <defs>
                <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#0078d4" stop-opacity="0.45" />
                    <stop offset="100%" stop-color="#0078d4" stop-opacity="0.02" />
                </linearGradient>
            </defs>
            @{
                var monthVals = _byMonth.Select(x => x.Total).ToList();
            }
            @for (int gi = 1; gi <= 4; gi++)
            {
                var y = 20 + gi * 50;
                <line x1="40" x2="780" y1="@y" y2="@y" stroke="#edebe9" stroke-width="1" />
            }
            @if (monthVals.Count > 1)
            {
                <path d="@AreaPath(monthVals, 800, 260, 40)" fill="url(#areaGrad)" />
                <path d="@LinePath(monthVals, 800, 260, 40)" fill="none" stroke="#0078d4" stroke-width="2.5" />
                @for (int i = 0; i < monthVals.Count; i++)
                {
                    var p = PointAt(i, monthVals.Count, monthVals, 800, 260, 40);
                    <circle cx="@p.x.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                            cy="@p.y.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                            r="4" fill="#fff" stroke="#0078d4" stroke-width="2">
                        <title>@_byMonth[i].Label: @_byMonth[i].Total.ToString("N0") ₺</title>
                    </circle>
                }
            }
        </svg>
        <div class="trend-axis">
            @foreach (var m in _byMonth)
            {
                <span>@m.Label</span>
            }
        </div>
    </FluentCard>

    <div class="az-grid-2" style="margin-top:16px;">
        <FluentCard>
            <h3 class="az-tile-title" style="margin:0 0 12px;">Distribution by Type (Pie)</h3>
            @{
                var pieTotal = _byType.Sum(x => x.Total);
                decimal piePos = 0;
            }
            <div style="display:flex; gap:16px; align-items:center;">
                <svg viewBox="0 0 220 220" style="width:220px; height:220px; flex:0 0 auto;">
                    @foreach (var (t, i) in _byType.Select((x, idx) => (x, idx)))
                    {
                        var pct = pieTotal == 0 ? 0 : t.Total * 100m / pieTotal;
                        <path d="@PiePath(piePos, pct, 110, 110, 100)"
                              fill="@DotColor(i)" stroke="#fff" stroke-width="2">
                            <title>@t.Type: @t.Total.ToString("N0") ₺ (@pct.ToString("N1")%)</title>
                        </path>
                        piePos += pct;
                    }
                </svg>
                <div class="legend-list">
                    @foreach (var (t, i) in _byType.Select((x, idx) => (x, idx)))
                    {
                        var pct = pieTotal == 0 ? 0 : t.Total * 100m / pieTotal;
                        <div class="legend-row">
                            <span class="legend-dot" style="background:@DotColor(i);"></span>
                            <span class="legend-label">@t.Type</span>
                            <span class="legend-value">@pct.ToString("N1")%</span>
                        </div>
                    }
                </div>
            </div>
        </FluentCard>

        <FluentCard>
            <h3 class="az-tile-title" style="margin:0 0 12px;">Department Share (Donut)</h3>
            @{
                var donTotal = _byDept.Sum(x => x.Total);
                decimal donPos = 0;
            }
            <div style="display:flex; gap:16px; align-items:center;">
                <svg viewBox="0 0 220 220" style="width:220px; height:220px; flex:0 0 auto;">
                    @foreach (var (d, i) in _byDept.Select((x, idx) => (x, idx)))
                    {
                        var pct = donTotal == 0 ? 0 : d.Total * 100m / donTotal;
                        <path d="@DonutPath(donPos, pct, 110, 110, 100, 60)"
                              fill="@DotColor(i)" stroke="#fff" stroke-width="2">
                            <title>@d.Department: @d.Total.ToString("N0") ₺ (@pct.ToString("N1")%)</title>
                        </path>
                        donPos += pct;
                    }
                    <text x="110" y="105" text-anchor="middle" font-size="13" fill="#605e5c">Total</text>
                    <text x="110" y="128" text-anchor="middle" font-size="18" font-weight="700" fill="#323130">
                        @donTotal.ToString("N0")
                    </text>
                </svg>
                <div class="legend-list">
                    @foreach (var (d, i) in _byDept.Select((x, idx) => (x, idx)))
                    {
                        var pct = donTotal == 0 ? 0 : d.Total * 100m / donTotal;
                        <div class="legend-row">
                            <span class="legend-dot" style="background:@DotColor(i);"></span>
                            <span class="legend-label">@d.Department</span>
                            <span class="legend-value">@pct.ToString("N1")%</span>
                        </div>
                    }
                </div>
            </div>
        </FluentCard>
    </div>

    <FluentCard Style="margin-top:16px;">
        <h3 class="az-tile-title" style="margin:0 0 12px;">Status Breakdown</h3>
        <div class="status-gauge-row">
            @{
                var statusTotal = _byStatus.Sum(x => x.Count);
            }
            @foreach (var s in _byStatus)
            {
                var pct = statusTotal == 0 ? 0 : (int)Math.Round((double)s.Count * 100.0 / statusTotal);
                var color = StatusColor(s.Status);
                var circ = 2 * Math.PI * 50;
                var dash = circ * pct / 100.0;
                <div class="status-gauge">
                    <svg viewBox="0 0 120 120" style="width:120px; height:120px;">
                        <circle cx="60" cy="60" r="50" fill="none" stroke="#edebe9" stroke-width="12" />
                        <circle cx="60" cy="60" r="50" fill="none" stroke="@color" stroke-width="12"
                                stroke-dasharray="@dash.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) @circ.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                stroke-linecap="round"
                                transform="rotate(-90 60 60)" />
                        <text x="60" y="58" text-anchor="middle" font-size="22" font-weight="700" fill="#323130">@pct%</text>
                        <text x="60" y="78" text-anchor="middle" font-size="11" fill="#605e5c">@s.Count items</text>
                    </svg>
                    <div class="status-gauge-label" style="color:@color;">@s.Status</div>
                    <div class="status-gauge-sub">@s.Total.ToString("N0") ₺</div>
                </div>
            }
        </div>
    </FluentCard>

    <div class="az-grid-2" style="margin-top:16px;">
        <FluentCard>
            <h3 class="az-tile-title" style="margin:0 0 12px;">Top 10 Employees</h3>
            <FluentDataGrid Items="@_topEmployees.AsQueryable()" GridTemplateColumns="0.6fr 1.4fr 1fr 0.6fr 1fr" ShowHover="true">
                <TemplateColumn Title="#">
                    <FluentBadge Appearance="Appearance.Accent">@(_topEmployees.IndexOf(context) + 1)</FluentBadge>
                </TemplateColumn>
                <PropertyColumn Property="@(x => x.FullName)" Title="Employee" Sortable="true" />
                <PropertyColumn Property="@(x => x.Department)" Title="Department" Sortable="true" />
                <PropertyColumn Property="@(x => x.Count)" Title="#" Sortable="true" Align="Align.End" />
                <TemplateColumn Title="Total" Align="Align.End">
                    <strong>@context.Total.ToString("N0") ₺</strong>
                </TemplateColumn>
            </FluentDataGrid>
        </FluentCard>

        <FluentCard>
            <h3 class="az-tile-title" style="margin:0 0 12px;">Activity Heatmap (Day × Month)</h3>
            <div class="heatmap">
                <div class="heatmap-header">
                    <div></div>
                    @foreach (var m in new[]{"J","F","M","A","M","J","J","A","S","O","N","D"})
                    {
                        <div class="heatmap-h">@m</div>
                    }
                </div>
                @{
                    var days = new[] { "Mon","Tue","Wed","Thu","Fri","Sat","Sun" };
                }
                @for (int r = 0; r < 7; r++)
                {
                    <div class="heatmap-row">
                        <div class="heatmap-d">@days[r]</div>
                        @for (int c = 0; c < 12; c++)
                        {
                            var v = _heatmap[r, c];
                            <div class="heatmap-cell" style="background:@HeatColor(v);" title="@days[r] / month @(c+1): @v items">
                                @(v > 0 ? v.ToString() : "")
                            </div>
                        }
                    </div>
                }
                <div class="heatmap-legend">
                    <span>Less</span>
                    <span class="heatmap-cell" style="background:@HeatColor(0);"></span>
                    <span class="heatmap-cell" style="background:@HeatColor(_heatmapMax/4);"></span>
                    <span class="heatmap-cell" style="background:@HeatColor(_heatmapMax/2);"></span>
                    <span class="heatmap-cell" style="background:@HeatColor(3*_heatmapMax/4);"></span>
                    <span class="heatmap-cell" style="background:@HeatColor(_heatmapMax);"></span>
                    <span>More</span>
                </div>
            </div>
        </FluentCard>
    </div>

    <FluentCard Style="margin-top:16px;">
        <FluentStack HorizontalAlignment="HorizontalAlignment.SpaceBetween" Style="margin-bottom:12px;">
            <h3 class="az-tile-title" style="margin:0;">@L.T("rep.byDeptTitle")</h3>
            <FluentButton Appearance="Appearance.Stealth"
                          IconStart="@(new Icons.Regular.Size16.ArrowDownload())"
                          OnClick="ExportAsync">@L.T("common.export")</FluentButton>
        </FluentStack>
        <FluentDataGrid Items="@_byDept.AsQueryable()" GridTemplateColumns="2fr 1fr 1.5fr 1.2fr 1fr" ShowHover="true">
            <PropertyColumn Property="@(x => x.Department)" Title="@L.T("rep.col.department")" Sortable="true" />
            <PropertyColumn Property="@(x => x.Count)" Title="@L.T("rep.col.count")" Sortable="true" Align="Align.End" />
            <PropertyColumn Property="@(x => x.Total)" Title="@L.T("rep.col.total")" Format="N2" Sortable="true" Align="Align.End" />
            <PropertyColumn Property="@(x => x.Avg)" Title="@L.T("rep.col.avg")" Format="N2" Sortable="true" Align="Align.End" />
            <TemplateColumn Title="@L.T("rep.col.share")">
                <FluentBadge Appearance="Appearance.Neutral" BackgroundColor="#dff6dd" Color="#107c10">
                    @(((decimal)context.Total * 100m / Math.Max(_total, 1m)).ToString("N0"))%
                </FluentBadge>
            </TemplateColumn>
        </FluentDataGrid>
    </FluentCard>
}

@code {
    private List<Incentive> _data = new();
    private bool _loading = true;
    private decimal _total;
    private decimal _avg;
    private string _topDept = "-";
    private decimal _topDeptAmount;
    private decimal _approvalRate;

    record DeptAgg(string Department, int Count, decimal Total, decimal Avg);
    record TypeAgg(string Type, decimal Total);
    record MonthAgg(string Label, decimal Total);
    record StatusAgg(string Status, int Count, decimal Total);
    record EmpAgg(string EmployeeNo, string FullName, string Department, int Count, decimal Total);

    private List<DeptAgg> _byDept = new();
    private List<TypeAgg> _byType = new();
    private List<MonthAgg> _byMonth = new();
    private List<StatusAgg> _byStatus = new();
    private List<EmpAgg> _topEmployees = new();
    private int[,] _heatmap = new int[7, 12];
    private decimal _byDeptMax;
    private decimal _byMonthMax;
    private int _heatmapMax;

    private static readonly string[] _palette =
    {
        "#0078d4", "#107c10", "#f7630c", "#5c2d91",
        "#a4262c", "#038387", "#8764b8", "#e3008c"
    };

    private string DotColor(int i) => _palette[i % _palette.Length];

    protected override async Task OnInitializedAsync()
    {
        L.Changed += StateHasChanged;
        await ReloadAsync();
    }

    public void Dispose() => L.Changed -= StateHasChanged;

    private async Task ReloadAsync()
    {
        _loading = true;
        try
        {
            var client = HttpFactory.CreateClient("Api");
            _data = await client.GetFromJsonAsync<List<Incentive>>("/api/incentives") ?? new();
            Compute();
        }
        finally { _loading = false; }
    }

    private void Print() { /* placeholder */ }

    private async Task ExportAsync()
    {
        await Excel.ExportAsync(
            $"reports_{DateTime.Now:yyyyMMdd_HHmm}.xlsx",
            "Reports",
            _byDept,
            ("Department", x => x.Department),
            ("Count",      x => x.Count),
            ("Total (₺)",  x => x.Total),
            ("Average",    x => x.Avg),
            ("Share %",    x => Math.Round((double)((decimal)x.Total * 100m / Math.Max(_total, 1m)), 2))
        );
        Toast.ShowSuccess("Report exported to Excel");
    }

    private void Compute()
    {
        _total = _data.Sum(x => x.Amount);
        _avg = _data.Count == 0 ? 0 : _total / _data.Count;
        _approvalRate = _data.Count == 0 ? 0
            : _data.Count(x => x.Status == "Approved") * 100m / _data.Count;

        _byDept = _data
            .GroupBy(x => x.Department)
            .Select(g => new DeptAgg(g.Key, g.Count(), g.Sum(x => x.Amount), g.Average(x => x.Amount)))
            .OrderByDescending(x => x.Total)
            .ToList();
        _byDeptMax = _byDept.Count == 0 ? 0 : _byDept.Max(x => x.Total);

        var top = _byDept.FirstOrDefault();
        if (top is not null)
        {
            _topDept = top.Department;
            _topDeptAmount = top.Total;
        }

        _byType = _data
            .GroupBy(x => x.IncentiveType)
            .Select(g => new TypeAgg(g.Key, g.Sum(x => x.Amount)))
            .OrderByDescending(x => x.Total)
            .ToList();

        _byMonth = _data
            .GroupBy(x => new { x.Date.Year, x.Date.Month })
            .Select(g => new MonthAgg(
                $"{System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.GetAbbreviatedMonthName(g.Key.Month)} {g.Key.Year % 100:00}",
                g.Sum(x => x.Amount)))
            .OrderBy(x => x.Label)
            .ToList();
        _byMonthMax = _byMonth.Count == 0 ? 0 : _byMonth.Max(x => x.Total);

        _byStatus = _data
            .GroupBy(x => x.Status)
            .Select(g => new StatusAgg(g.Key, g.Count(), g.Sum(x => x.Amount)))
            .OrderByDescending(x => x.Count)
            .ToList();

        _topEmployees = _data
            .GroupBy(x => new { x.EmployeeNo, x.FullName, x.Department })
            .Select(g => new EmpAgg(g.Key.EmployeeNo, g.Key.FullName, g.Key.Department, g.Count(), g.Sum(x => x.Amount)))
            .OrderByDescending(x => x.Total)
            .Take(10)
            .ToList();

        _heatmap = new int[7, 12];
        foreach (var x in _data)
        {
            var d = x.Date.ToDateTime(TimeOnly.MinValue);
            var dow = ((int)d.DayOfWeek + 6) % 7; // Mon=0..Sun=6
            var month = d.Month - 1;
            _heatmap[dow, month]++;
        }
        _heatmapMax = 0;
        for (int i = 0; i < 7; i++)
            for (int j = 0; j < 12; j++)
                if (_heatmap[i, j] > _heatmapMax) _heatmapMax = _heatmap[i, j];
    }

    // ===== SVG chart helpers =====
    private string PiePath(decimal startPct, decimal sweepPct, double cx, double cy, double r)
    {
        if (sweepPct <= 0) return "";
        if (sweepPct >= 100) sweepPct = 99.999m;
        double a0 = (double)(startPct / 100m) * 2 * Math.PI - Math.PI / 2;
        double a1 = (double)((startPct + sweepPct) / 100m) * 2 * Math.PI - Math.PI / 2;
        double x0 = cx + r * Math.Cos(a0);
        double y0 = cy + r * Math.Sin(a0);
        double x1 = cx + r * Math.Cos(a1);
        double y1 = cy + r * Math.Sin(a1);
        int large = sweepPct > 50 ? 1 : 0;
        return $"M {cx:F2} {cy:F2} L {x0:F2} {y0:F2} A {r:F2} {r:F2} 0 {large} 1 {x1:F2} {y1:F2} Z"
            .Replace(',', '.');
    }

    private string DonutPath(decimal startPct, decimal sweepPct, double cx, double cy, double r, double inner)
    {
        if (sweepPct <= 0) return "";
        if (sweepPct >= 100) sweepPct = 99.999m;
        double a0 = (double)(startPct / 100m) * 2 * Math.PI - Math.PI / 2;
        double a1 = (double)((startPct + sweepPct) / 100m) * 2 * Math.PI - Math.PI / 2;
        double x0o = cx + r * Math.Cos(a0), y0o = cy + r * Math.Sin(a0);
        double x1o = cx + r * Math.Cos(a1), y1o = cy + r * Math.Sin(a1);
        double x0i = cx + inner * Math.Cos(a1), y0i = cy + inner * Math.Sin(a1);
        double x1i = cx + inner * Math.Cos(a0), y1i = cy + inner * Math.Sin(a0);
        int large = sweepPct > 50 ? 1 : 0;
        return string.Format(System.Globalization.CultureInfo.InvariantCulture,
            "M {0:F2} {1:F2} A {2:F2} {2:F2} 0 {3} 1 {4:F2} {5:F2} L {6:F2} {7:F2} A {8:F2} {8:F2} 0 {3} 0 {9:F2} {10:F2} Z",
            x0o, y0o, r, large, x1o, y1o, x0i, y0i, inner, x1i, y1i);
    }

    private string AreaPath(IReadOnlyList<decimal> values, double w, double h, double pad)
    {
        if (values.Count == 0) return "";
        double max = (double)values.Max();
        if (max <= 0) max = 1;
        double stepX = (w - 2 * pad) / Math.Max(1, values.Count - 1);
        var sb = new System.Text.StringBuilder();
        sb.Append(System.Globalization.CultureInfo.InvariantCulture, $"M {pad:F2} {h - pad:F2} ");
        for (int i = 0; i < values.Count; i++)
        {
            double x = pad + i * stepX;
            double y = h - pad - ((double)values[i] / max) * (h - 2 * pad);
            sb.Append(System.Globalization.CultureInfo.InvariantCulture, $"L {x:F2} {y:F2} ");
        }
        sb.Append(System.Globalization.CultureInfo.InvariantCulture, $"L {w - pad:F2} {h - pad:F2} Z");
        return sb.ToString();
    }

    private string LinePath(IReadOnlyList<decimal> values, double w, double h, double pad)
    {
        if (values.Count == 0) return "";
        double max = (double)values.Max();
        if (max <= 0) max = 1;
        double stepX = (w - 2 * pad) / Math.Max(1, values.Count - 1);
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < values.Count; i++)
        {
            double x = pad + i * stepX;
            double y = h - pad - ((double)values[i] / max) * (h - 2 * pad);
            sb.Append(System.Globalization.CultureInfo.InvariantCulture,
                $"{(i == 0 ? "M" : "L")} {x:F2} {y:F2} ");
        }
        return sb.ToString();
    }

    private (double x, double y) PointAt(int i, int n, IReadOnlyList<decimal> values, double w, double h, double pad)
    {
        double max = (double)values.Max();
        if (max <= 0) max = 1;
        double stepX = (w - 2 * pad) / Math.Max(1, n - 1);
        double x = pad + i * stepX;
        double y = h - pad - ((double)values[i] / max) * (h - 2 * pad);
        return (x, y);
    }

    private string HeatColor(int v)
    {
        if (_heatmapMax == 0) return "#f3f2f1";
        var t = (double)v / _heatmapMax;
        // light blue -> dark blue
        int r = (int)(232 - 232 * t);
        int g = (int)(241 - 128 * t);
        int b = (int)(253 - 41 * t);
        return $"rgb({r},{g},{b})";
    }

    private string StatusColor(string s) => s switch
    {
        "Approved" => "#107c10",
        "Pending"  => "#f7630c",
        "Rejected" => "#a4262c",
        _          => "#605e5c"
    };
}