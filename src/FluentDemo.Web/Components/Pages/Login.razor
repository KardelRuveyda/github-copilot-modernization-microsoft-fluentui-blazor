@page "/login"
@layout EmptyLayout
@inject AuthState Auth
@inject LocalizationService L
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>@L.T("login.submit") - FluentUI Demo</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <div style="display:flex; justify-content:space-between; align-items:flex-start;">
            <div class="login-logo">İ</div>
            <LanguageSwitcher />
        </div>
        <h1 class="login-title">@L.T("login.title")</h1>
        <p class="login-subtitle">@L.T("login.subtitle")</p>

        <div>
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="14">
                <div style="width:100%;">
                    <label class="login-label">@L.T("login.username")</label>
                    <input class="login-input"
                           type="text"
                           placeholder="admin"
                           autocomplete="username"
                           @bind="_model.Username"
                           @bind:event="oninput"
                           @onkeydown="OnKey" />
                </div>

                <div style="width:100%;">
                    <label class="login-label">@L.T("login.password")</label>
                    <input class="login-input"
                           type="password"
                           placeholder="••••"
                           autocomplete="current-password"
                           @bind="_model.Password"
                           @bind:event="oninput"
                           @onkeydown="OnKey" />
                </div>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false">
                        @_error
                    </FluentMessageBar>
                }

                <FluentButton Appearance="Appearance.Accent"
                              OnClick="HandleLogin"
                              Loading="@_busy"
                              Style="width:100%; height:42px;">
                    @L.T("login.submit")
                </FluentButton>

                <div class="demo-hint">
                    @((MarkupString)L.T("login.hint"))
                </div>
            </FluentStack>
        </div>
    </div>
</div>

@code {
    private LoginModel _model = new();
    private string? _error;
    private bool _busy;

    protected override void OnInitialized() => L.Changed += StateHasChanged;
    public void Dispose() => L.Changed -= StateHasChanged;

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private async Task HandleLogin()
    {
        _error = null;
        _busy = true;
        try
        {
            var client = HttpFactory.CreateClient("Api");
            var resp = await client.PostAsJsonAsync("/api/auth/login",
                new LoginRequest(_model.Username, _model.Password));
            var result = await resp.Content.ReadFromJsonAsync<LoginResult>();

            if (result?.Success == true)
            {
                Auth.SignIn(_model.Username);
                Nav.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _error = result?.Message ?? L.T("login.fail");
            }
        }
        catch (Exception ex)
        {
            _error = L.T("login.connectError") + ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    public class LoginModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
